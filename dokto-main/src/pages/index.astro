---
import Layout from "@layouts/Default.astro";
import ButtonMain from "@components/base/ButtonMain.astro";
import HeroMain from "@components/hero/HeroMain.astro";
import SectionMuted from "@components/section/SectionMuted.astro";
import Container from "@components/section/Container.astro";
import SectionTitle from "@components/section/SectionTitle.astro";
import IconBlock from "@components/content/IconBlock.astro";
import Toolbar from "@components/content/doctors/grid/Toolbar.astro";
import Filters from "@components/content/doctors/grid/Filters.astro";
import Grid from "@components/content/doctors/grid/Grid.astro";
import SideStatsRight from "@components/content/features/SideStatsRight.astro";
import SideStatsLeft from "@components/content/features/SideStatsLeft.astro";
import Pricing from "@components/content/Pricing.astro";
import Cta from "@components/content/Cta.astro";
import Testimonials from "@components/content/Testimonials.astro";
import Instalaciones from "@components/content/Instalaciones.astro";
---

<Layout title="Home">
  <HeroMain />

  <SectionMuted class="'fade-in-section'">
    <Container>
      <SectionTitle
        title="Que tratamos?"
        subtitle="Texto descriptivo de los servicios que ofrecemos, con un lenguaje claro y accesible para nuestros pacientes."
        minititle="Nuestros Servicios"
      />

      <div
        class="grid md:grid-cols-3 ltablet:grid-cols-4 lg:grid-cols-4 gap-x-6 gap-y-12"
        x-intersect="activeStep = ''"
      >
        <!-- Item -->
        <div>
          <IconBlock
            title="Accidentes Laborales"
            text="Atención inmediata y especializada para trabajadores lesionados en el entorno laboral, con servicios de emergencia, rehabilitación y asesoramiento legal."
            icon="ph:timer-duotone"
            class="'text-primary-600'"
          />
        </div>
        <!-- Item -->
        <div>
          <IconBlock
            title="Lesiones Deportivas"
            text="Atención especializada para deportistas, con servicios de diagnóstico, tratamiento y rehabilitación."
            icon="ph:first-aid-duotone"
            class="'text-rose-600'"
          />
        </div>
        <!-- Item -->
        <div>
          <IconBlock
            title="Patologías Crónicas y Agudas"
            text="Aención integral para pacientes con enfermedades crónicas o agudas, con servicios de diagnóstico, tratamiento y seguimiento personalizado."
            icon="ph:first-aid-kit-duotone"
            class="'text-primary-600'"
          />
        </div>
        <!-- Item -->
        <div>
          <IconBlock
            title="Lesiones Traumatológicas de niños"
            text="Atención especializada para niños con lesiones traumáticas, con servicios de diagnóstico, tratamiento y rehabilitación."
            icon="ph:heartbeat-duotone"
            class="'text-rose-500'"
          />
        </div>
        <!-- Item -->
        <div>
          <IconBlock
            title="Neurorehabilitación"
            text="Atención especializada para pacientes con lesiones neurológicas, con servicios de diagnóstico, tratamiento y rehabilitación."
            icon="ph:video-camera-duotone"
            class="'text-primary-600'"
          />
        </div>
        <!-- Item -->
        <div>
          <IconBlock
            title="Audio consultas"
            text="Atención médica a distancia a través de llamadas telefónicas, con profesionales disponibles para resolver dudas y brindar orientación."
            icon="ph:phone-duotone"
            class="'text-primary-600'"
          />
        </div>
        <!-- Item -->
        <div>
          <IconBlock
            title="Citas"
            text="Gestión de citas médicas de manera eficiente, con recordatorios y seguimiento personalizado."
            icon="ph:calendar-duotone"
            class="'text-primary-600'"
          />
        </div>
        <!-- Item -->
        <div>
          <IconBlock
            title="Medicina"
            text="Atención médica integral, con servicios de diagnóstico, tratamiento y seguimiento personalizado."
            icon="ph:pill-duotone"
            class="'text-primary-600'"
          />
        </div>
      </div>
    </Container>
  </SectionMuted>

  <SectionMuted class="'border-b border-muted-200 dark:border-muted-800 fade-in-section'">
    <Container>
      <div id="doctors">
        <SectionTitle
          title="Equipo de Profesionales"
          subtitle="Nuestro equipo de profesionales altamente capacitados y dedicados a brindar atención médica de calidad, con experiencia en diversas especialidades para satisfacer las necesidades de nuestros pacientes."
          minititle="Nuestros Doctores"
          class="'mx-auto text-center'"
        />
      </div>

      <div x-data="doctors()" x-intersect="activeStep = 'spy-1'">
        <!--Grid wrapper-->
        <div class="py-10">
          <div class="grid grid-cols-12 md:gap-12 pb-20">
            <!--Filters
            <div class="hidden lg:block col-span-12 lg:col-span-3">
              <Filters />
            </div>-->
            <!--Content-->
            <div class="col-span-12 lg:col-span-80">
              <!--Subgrid-->
              <Grid />
            </div>
          </div>
        </div>
      </div>
    </Container>
  </SectionMuted>

  <SectionMuted class="'overflow-hidden fade-in-section'">
    <Container>
      <div class="py-10">
        <SideStatsRight />
      </div>
    </Container>
  </SectionMuted>

  <SectionMuted class="'fade-in-section'">
    <Container>
      <Pricing />
    </Container>
  </SectionMuted>

  <SectionMuted class="'fade-in-section'">
    <Container>
      <SectionTitle
        title="Nuestras Instalaciones"
        subtitle="Contamos con tres sectores diseñados para acompañar cada etapa de tu recuperación, desde la rehabilitación inicial hasta el retorno pleno a la actividad."
        minititle="Infraestructura"
      />
      <Instalaciones />
    </Container>
  </SectionMuted>

  <SectionMuted class="'fade-in-section'">
    <Container>
      <Cta />
    </Container>
  </SectionMuted>
</Layout>
