---
import Layout from "@layouts/Default.astro";
import HeroMain from "@components/hero/HeroMain.astro";
import SectionMuted from "@components/section/SectionMuted.astro";
import Container from "@components/section/Container.astro";
import SectionTitle from "@components/section/SectionTitle.astro";
import IconBlock from "@components/base/IconBlock.astro";
import Grid from "@components/content/doctors/grid/Grid.astro";
import Tratamientos from "@components/content/features/Tratamientos.astro";
import TerapiasAlternativas from "@components/content/features/TerapiasAlternativas.astro";
import Instalaciones from "@components/content/features/Instalaciones.astro"; 
---

<Layout title="Home">
  <HeroMain />

  <SectionMuted>
    <Container>
      <SectionTitle
        title="Que tratamos?"
        subtitle="Texto descriptivo de los servicios que ofrecemos, con un lenguaje claro y accesible para nuestros pacientes."
        minititle="Nuestros Servicios"
        class="'animate-scale'"
      />
      <div
        class="grid md:grid-cols-3 ltablet:grid-cols-4 lg:grid-cols-4 gap-x-6 gap-y-12"
        x-intersect="activeStep = ''"
      >
        <!-- Item -->
        <div class="animate-on-scroll">
          <IconBlock
            title="Accidentes Laborales"
            text="Atención inmediata y especializada para trabajadores lesionados en el entorno laboral, con servicios de emergencia, rehabilitación y asesoramiento legal."
            icon="ph:timer-duotone"
            class="'text-primary-600'"
          />
        </div>
        <!-- Item -->
        <div class="animate-on-scroll">
          <IconBlock
            title="Lesiones Deportivas"
            text="Atención especializada para deportistas, con servicios de diagnóstico, tratamiento y rehabilitación."
            icon="ph:first-aid-duotone"
            class="'text-rose-600'"
          />
        </div>
        <!-- Item -->
        <div class="animate-on-scroll">
          <IconBlock
            title="Patologías Crónicas y Agudas"
            text="Aención integral para pacientes con enfermedades crónicas o agudas, con servicios de diagnóstico, tratamiento y seguimiento personalizado."
            icon="ph:first-aid-kit-duotone"
            class="'text-primary-600'"
          />
        </div>
        <!-- Item -->
        <div class="animate-on-scroll">
          <IconBlock
            title="Lesiones Traumatológicas de niños"
            text="Atención especializada para niños con lesiones traumáticas, con servicios de diagnóstico, tratamiento y rehabilitación."
            icon="ph:heartbeat-duotone"
            class="'text-rose-500'"
          />
        </div>
        <!-- Item -->
        <div class="animate-on-scroll">
          <IconBlock
            title="Neurorehabilitación"
            text="Atención especializada para pacientes con lesiones neurológicas, con servicios de diagnóstico, tratamiento y rehabilitación."
            icon="ph:video-camera-duotone"
            class="'text-primary-600'"
          />
        </div>
        <!-- Item -->
        <div class="animate-on-scroll">
          <IconBlock
            title="Audio consultas"
            text="Atención médica a distancia a través de llamadas telefónicas, con profesionales disponibles para resolver dudas y brindar orientación."
            icon="ph:phone-duotone"
            class="'text-primary-600'"
          />
        </div>
        <!-- Item -->
        <div class="animate-on-scroll">
          <IconBlock
            title="Citas"
            text="Gestión de citas médicas de manera eficiente, con recordatorios y seguimiento personalizado."
            icon="ph:calendar-duotone"
            class="'text-primary-600'"
          />
        </div>
        <!-- Item -->
        <div class="animate-on-scroll">
          <IconBlock
            title="Medicina"
            text="Atención médica integral, con servicios de diagnóstico, tratamiento y seguimiento personalizado."
            icon="ph:pill-duotone"
            class="'text-primary-600'"
          />
        </div>
      </div>
    </Container>
  </SectionMuted>

  <SectionMuted
    class="'border-b border-muted-200 dark:border-muted-800 fade-in-section'"
  >
    <Container>
      <div id="doctors">
        <SectionTitle
          title="Equipo de Profesionales"
          subtitle="Nuestro equipo de profesionales altamente capacitados y dedicados a brindar atención médica de calidad, con experiencia en diversas especialidades para satisfacer las necesidades de nuestros pacientes."
          minititle="Nuestros Doctores"
          class="'mx-auto text-center animate-on-scroll'"
        />
      </div>

      <div x-data="doctors()" x-intersect="activeStep = 'spy-1'">
        <!--Grid wrapper-->
        <div class="py-10">
          <div class="grid grid-cols-12 md:gap-12 pb-5">
            <!--Content-->
            <div class="col-span-12 lg:col-span-80">
              <!--Subgrid-->
              <Grid />
            </div>
          </div>
        </div>
      </div>
    </Container>
  </SectionMuted>

  <SectionMuted class="'overflow-hidden fade-in-section'">
    <div x-data="treatments()" x-intersect="activeStep = 'spy-2'">
      <Container>
        <div class="py-10 pt-0">
          <Tratamientos />
        </div>
      </Container>

      <!-- Modal de Tratamientos - Fullscreen -->
      <!-- Modal -->
      <div
        x-cloak
        class="fixed inset-0 z-50 flex items-center justify-center"
        x-show="modalOpen && activeCard"
      >
        <!-- BACKDROP -->
        <div
          class="absolute inset-0 bg-black/60 backdrop-blur-sm"
          x-show="modalOpen"
          x-transition:enter="transition-opacity ease-out duration-300"
          x-transition:enter-start="opacity-0"
          x-transition:enter-end="opacity-100"
          x-transition:leave="transition-opacity ease-in duration-200"
          x-transition:leave-start="opacity-100"
          x-transition:leave-end="opacity-0"
          @click="modalOpen = false"
        >
        </div>

        <!-- MODAL -->
        <div
          @click.stop
          x-show="modalOpen"
          x-transition:enter="transition transform ease-out duration-300"
          x-transition:enter-start="opacity-0 scale-95 translate-y-4"
          x-transition:enter-end="opacity-100 scale-100 translate-y-0"
          x-transition:leave="transition transform ease-[cubic-bezier(0.4,0,0.2,1)] duration-250"
          x-transition:leave-start="opacity-100 scale-100 translate-y-0"
          x-transition:leave-end="opacity-0 scale-95 translate-y-4"
          class="relative z-50 w-full max-w-2xl mx-3 max-h-[95vh]"
        >
          <div
            class="bg-white dark:bg-muted-900 rounded-2xl shadow-2xl overflow-hidden"
          >
            <div class="flex flex-col md:flex-row gap-6 p-6">
              <!-- IMAGEN -->
              <div class="w-full md:w-2/5">
                <div
                  class="relative w-full h-64 md:h-80 rounded-lg overflow-hidden"
                >
                  <img
                    :src="activeCard?.image"
                    class="w-full h-full object-cover"
                  />
                </div>
              </div>

              <!-- CONTENIDO -->
              <div class="w-full md:w-3/5 flex flex-col justify-between">
                <div>
                  <h3
                    class="font-heading font-semibold text-3xl text-muted-800 dark:text-white mb-3"
                    x-text="activeCard?.title"
                  >
                  </h3>

                  <p
                    class="text-base text-muted-600 dark:text-muted-400 leading-relaxed"
                    x-text="activeCard?.fullDescription"
                  >
                  </p>
                </div>

                <!-- BOTÓN -->
                <div class="flex pt-6 mt-auto">
                  <button
                    @click="modalOpen = false"
                    class="flex-1 px-4 py-3 rounded-lg bg-primary-500 hover:bg-primary-600 text-white font-semibold transition-colors"
                  >
                    Cerrar
                  </button>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </SectionMuted>

  <SectionMuted class="'fade-in-section'">
    <Container>
      <TerapiasAlternativas />
    </Container>
  </SectionMuted>

  <SectionMuted class="'fade-in-section'">
    <Container>
      <div id="instalaciones">
        <SectionTitle
          title="Nuestras Instalaciones"
          subtitle="Contamos con tres sectores diseñados para acompañar cada etapa de tu recuperación, desde la rehabilitación inicial hasta el retorno pleno a la actividad."
          minititle="Infraestructura"
          class="'animate-scale'"
        />
      </div>
      <Instalaciones />
    </Container>
  </SectionMuted>
</Layout>
