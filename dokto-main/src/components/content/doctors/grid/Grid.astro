          @click="activeDoctor = { name: 'Dr. Aaron Zimmerman', title: 'Gynaecologist', bio: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Ergo illi intellegunt quid', img: '/img/illustrations/doctors/doctor-2.svg', rating: '4.4/5' }; modalOpen = true"
          class="absolute -top-16 left-1/2 -translate-x-1/2 w-full max-w-[170px] ptablet:max-w-[150px] transition-transform duration-300 transform-gpu group-hover:scale-110 cursor-pointer"
          src="/img/illustrations/doctors/laura.jpg"
          alt="Doctor"
        />
      </div>
      <div class="font-sans px-4 pb-4">
        <h4 class="font-semibold text-muted-800 dark:text-muted-100">
          Lic. Laura Brizuela
        </h4>
        <p class="text-sm text-muted-400">Lic. en Kinesiologia y Fisioterapia</p>
      </div>
      <div class="px-4 pb-4">
        <p class="text-sm ptablet:text-xs text-muted-500 dark:text-muted-400">
          Lorem ipsum dolor sit amet, consectetur adipiscing elit. Ergo illi
          intellegunt quid
        </p>
      </div>
    </Card>
  </div>
  <!-- Doctor -->
  <div x-show="activeCategory === 'all' || activeCategory === 'neurology'" class="group">
    <Card class="'p-0 pt-20 transition-all duration-300 hover:shadow-2xl hover:scale-105'">
      <div
        class="relative w-full h-40 rounded-t-lg bg-muted-200 dark:bg-muted-800 overflow-visible -mt-20 mb-4 px-4"
      >
        <img
          @click="activeDoctor = { name: 'Dr. Michael Harris', title: 'Neurologist', bio: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Ergo illi intellegunt quid', img: '/img/illustrations/doctors/doctor-3.svg', rating: '5/5' }; modalOpen = true"
          class="absolute -top-16 left-1/2 -translate-x-1/2 w-full max-w-[170px] ptablet:max-w-[150px] transition-transform duration-300 transform-gpu group-hover:scale-110 cursor-pointer"
          src="/img/illustrations/doctors/jorge.jpg"
          alt="Doctor"
        />
      </div>
      <div class="font-sans px-4 pb-4">
        <h4 class="font-semibold text-muted-800 dark:text-muted-100">
          Lic. Jorge Castellanos
        </h4>
        <p class="text-sm text-muted-400">Lic. en Kinesiologia y Fisioterapia</p>
      </div>
      <div class="px-4 pb-4">
        <p class="text-sm ptablet:text-xs text-muted-500 dark:text-muted-400">
          Lorem ipsum dolor sit amet, consectetur adipiscing elit. Ergo illi
          intellegunt quid
        </p>
      </div>
    </Card>
  </div>
  <!-- Doctor -->
  <div x-show="activeCategory === 'all' || activeCategory === 'dermatology'" class="group">
    <Card class="'p-0 pt-20 transition-all duration-300 hover:shadow-2xl hover:scale-105'">
      <div
        class="relative w-full h-40 rounded-t-lg bg-muted-200 dark:bg-muted-800 overflow-visible -mt-20 mb-4 px-4"
      >
        <img
          @click="activeDoctor = { name: 'Dr. Eliana Dasilva', title: 'Dermatologist', bio: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Ergo illi intellegunt quid', img: '/img/illustrations/doctors/doctor-4.svg', rating: '4.8/5' }; modalOpen = true"
          class="absolute -top-16 left-1/2 -translate-x-1/2 w-full max-w-[170px] ptablet:max-w-[150px] transition-transform duration-300 transform-gpu group-hover:scale-110 cursor-pointer"
          src="/img/illustrations/doctors/juan.jpg"
          alt="Doctor"
        />
      </div>
      <div class="font-sans px-4 pb-4">
        <h4 class="font-semibold text-muted-800 dark:text-muted-100">
          Lic. Montellano Juan
        </h4>
        <p class="text-sm text-muted-400">Lic. en Kinesiologia y Fisioterapia</p>
      </div>
      <div class="px-4 pb-4">
        <p class="text-sm ptablet:text-xs text-muted-500 dark:text-muted-400">
          Lorem ipsum dolor sit amet, consectetur adipiscing elit. Ergo illi
          intellegunt quid
        </p>
      </div>
    </Card>
  </div>
  <!-- Doctor -->
  <div x-show="activeCategory === 'all' || activeCategory === 'general'" class="group">
    <Card class="'p-0 pt-20 transition-all duration-300 hover:shadow-2xl hover:scale-105'">
      <div
        class="relative w-full h-40 rounded-t-lg bg-muted-200 dark:bg-muted-800 overflow-visible -mt-20 mb-4 px-4"
      >
        <img
          @click="activeDoctor = { name: 'Dr. Clark Novak', title: 'Generalist', bio: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Ergo illi intellegunt quid', img: '/img/illustrations/doctors/doctor-5.svg', rating: '4.5/5' }; modalOpen = true"
          class="absolute -top-16 left-1/2 -translate-x-1/2 w-full max-w-[170px] ptablet:max-w-[150px] transition-transform duration-300 transform-gpu group-hover:scale-110 cursor-pointer"
          src="/img/illustrations/doctors/juan.jpg"
          alt="Doctor"
        />
      </div>
      <div class="font-sans px-4 pb-4">
        <h4 class="font-semibold text-muted-800 dark:text-muted-100">
          Lic. Estrella Eduardo
        </h4>
        <p class="text-sm text-muted-400">Lic. en Kinesiologia y Fisioterapia</p>
      </div>
      <div class="px-4 pb-4">
        <p class="text-sm ptablet:text-xs text-muted-500 dark:text-muted-400">
          Lorem ipsum dolor sit amet, consectetur adipiscing elit. Ergo illi
          intellegunt quid
        </p>
      </div>
    </Card>
  </div>
  
  
<!-- Modal -->
<div x-cloak x-show="modalOpen" x-transition.opacity class="fixed inset-0 z-50 flex items-center justify-center">
  <!-- Backdrop -->
  <div class="absolute inset-0 bg-black/60" @click="modalOpen = false"></div>

  <!-- Modal content -->
  <div @click.stop x-show="modalOpen" x-transition class="relative z-50 w-full max-w-3xl mx-4">
    <div class="bg-white dark:bg-muted-900 rounded-lg shadow-lg overflow-hidden">
      <div class="p-6 md:flex gap-6">
        <div class="w-full md:w-1/3 flex items-end">
          <div class="relative w-full h-44 rounded-lg bg-muted-200 dark:bg-muted-800 overflow-hidden">
            <img :src="activeDoctor ? activeDoctor.img : ''" alt="" class="absolute bottom-0 inset-x-0 mx-auto w-full max-w-[220px] transition-transform duration-300" />
          </div>
        </div>
        <div class="w-full md:w-2/3">
          <h3 class="text-xl font-semibold text-muted-800 dark:text-muted-100" x-text="activeDoctor ? activeDoctor.name : ''"></h3>
          <p class="text-sm text-muted-500 dark:text-muted-400 mt-1" x-text="activeDoctor ? activeDoctor.title : ''"></p>
          <div class="mt-4 text-muted-600 dark:text-muted-300" x-text="activeDoctor ? activeDoctor.bio : ''"></div>
          <div class="mt-4 flex items-center gap-2">
            <iconify-icon class="iconify w-5 h-5 text-yellow-400" icon="uiw:star-on"></iconify-icon>
            <span class="font-semibold text-sm text-muted-500 dark:text-muted-400" x-text="activeDoctor ? activeDoctor.rating : ''"></span>
          </div>
        </div>
      </div>
      <div class="p-4 border-t border-muted-200 dark:border-muted-800 flex justify-end">
        <button class="px-4 py-2 rounded bg-muted-100 dark:bg-muted-800 text-muted-700" @click="modalOpen = false">Cerrar</button>
      </div>
    </div>
  </div>
</div>
