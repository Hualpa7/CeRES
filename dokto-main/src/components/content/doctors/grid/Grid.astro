---
import Card from "@components/base/Card.astro";
---

<div class="grid md:grid-cols-3 ltablet:grid-cols-3 lg:grid-cols-3 gap-x-6 ptablet:gap-x-4 gap-y-20 pt-10">
  <div x-show="activeCategory === 'all' || activeCategory === 'cardiology'" class="group">
    <Card class="'p-0 pt-20 transition-all duration-300 hover:shadow-2xl hover:scale-105'">
      <div
        class="relative w-full h-40 rounded-t-lg bg-muted-200 dark:bg-muted-800 overflow-visible -mt-20 mb-4 px-4"
      >
        <img
          @click="activeDoctor = { name: 'Lic. Facundo Sarmiento', title: 'Lic. en Kinesiologia y Fisioterapia', bio: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Ergo illi intellegunt quid', img: '/img/illustrations/doctors/doctor-1.svg', rating: '4.8/5' }; modalOpen = true"
          class="absolute -top-16 left-1/2 -translate-x-1/2 w-full max-w-[170px] ptablet:max-w-[150px] transition-transform duration-300 transform-gpu group-hover:scale-110 cursor-pointer"
          src="/img/illustrations/doctors/facundo.jpg"
          alt="Doctor"
        />
      </div>
      <div class="font-sans px-4 pb-4">
        <h4 class="font-semibold text-muted-800 dark:text-muted-100">
          Lic. Facundo Sarmiento
        </h4>
        <p class="text-sm text-muted-400">Lic. en Kinesiologia y Fisioterapia</p>
      </div>
      <div class="px-4 pb-4">
        <p class="text-sm ptablet:text-xs text-muted-500 dark:text-muted-400">
          Lorem ipsum dolor sit amet, consectetur adipiscing elit. Ergo illi
          intellegunt quid
        </p>
      </div>
    </Card>
  </div>
  <!-- Doctor -->
  <div x-show="activeCategory === 'all' || activeCategory === 'gynaecology'" class="group">
    <Card class="'p-0 pt-20 transition-all duration-300 hover:shadow-2xl hover:scale-105'">
      <div
        class="relative w-full h-40 rounded-t-lg bg-muted-200 dark:bg-muted-800 overflow-visible -mt-20 mb-4 px-4"
      >
