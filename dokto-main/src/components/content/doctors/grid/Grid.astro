---
import Card from "@components/base/Card.astro";
---

<div
  class="grid md:grid-cols-3 ltablet:grid-cols-3 lg:grid-cols-3 gap-x-6 ptablet:gap-x-4 gap-y-32 pt-10"
>
  <div class="group animate-on-scroll">
    <Card
      class="'cursor-pointer will-change-transform p-0 pt-20 duration-400 hover:shadow-2xl hover:scale-105 hover:bg-slate-300 dark:hover:bg-muted-700 hover:translate-y-[-28px]'"
    >
      <div
        class="relative w-full h-40 rounded-t-lg bg-muted-200 dark:bg-muted-800 overflow-visible -mt-20 mb-4"
      >
        <img
          @click="activeDoctor = { name: 'Lic. Facundo Sarmiento', title: 'Lic. en Kinesiologia y Fisioterapia', bio: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Ergo illi intellegunt quid', img: '/img/illustrations/doctors/facundo.jpg' }; modalOpen = true"
          class="absolute left-1/2 -translate-x-1/2 -translate-y-1/3 w-full max-w-[240px] ptablet:max-w-[150px] transition-transform duration-400"
          src="/img/illustrations/doctors/facundo1.png"
          alt="Doctor"
        />
      </div>
      <div class="font-sans px-4 pb-4">
        <h4 class="font-semibold text-muted-800 dark:text-muted-100">
          Lic. Facundo Sarmiento
        </h4>
        <p class="text-sm text-muted-400">
          Lic. en Kinesiologia y Fisioterapia
        </p>
      </div>
      <div class="px-4 pb-4">
        <p class="text-sm ptablet:text-xs text-muted-500 dark:text-muted-400">
          Lorem ipsum dolor sit amet, consectetur adipiscing elit. Ergo illi
          intellegunt quid
        </p>
      </div>
    </Card>
  </div>
  <!-- Doctor -->
  <div class="group animate-on-scroll">
    <Card
      class="'cursor-pointer will-change-transform p-0 pt-20 duration-400 hover:shadow-2xl hover:scale-105 hover:bg-slate-300 dark:hover:bg-muted-700 hover:translate-y-[-28px]'"
    >
      <div
        class="relative w-full h-40 rounded-t-lg bg-muted-200 dark:bg-muted-800 overflow-visible -mt-20 mb-4"
      >
        <img
          @click="activeDoctor = { name: 'Lic. Laura Brizuela', title: 'Lic. en Kinesiologia y Fisioterapia', bio: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Ergo illi intellegunt quid', img: '/img/illustrations/doctors/laura.jpg', rating: '4.4/5' }; modalOpen = true"
          class="absolute left-1/2 -translate-x-1/2 -translate-y-1/3 w-full max-w-[240px] ptablet:max-w-[150px] transition-transform duration-400"
          src="/img/illustrations/doctors/laura2.png"
          alt="Doctor"
        />
      </div>
      <div class="font-sans px-4 pb-4">
        <h4 class="font-semibold text-muted-800 dark:text-muted-100">
          Lic. Laura Brizuela
        </h4>
        <p class="text-sm text-muted-400">
          Lic. en Kinesiologia y Fisioterapia
        </p>
      </div>
      <div class="px-4 pb-4">
        <p class="text-sm ptablet:text-xs text-muted-500 dark:text-muted-400">
          Lorem ipsum dolor sit amet, consectetur adipiscing elit. Ergo illi
          intellegunt quid
        </p>
      </div>
    </Card>
  </div>
  <!-- Doctor -->
  <div class="group animate-on-scroll">
    <Card
      class="'cursor-pointer will-change-transform p-0 pt-20 duration-400 hover:shadow-2xl hover:scale-105 hover:bg-slate-300 dark:hover:bg-muted-700 hover:translate-y-[-28px]'"
    >
      <div
        class="relative w-full h-40 rounded-t-lg bg-muted-200 dark:bg-muted-800 overflow-visible -mt-20 mb-4"
      >
        <img
          @click="activeDoctor = { name: 'Lic. Jorge Castellanos', title: 'Lic. en Kinesiologia y Fisioterapia', bio: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Ergo illi intellegunt quid', img: '/img/illustrations/doctors/jorge.jpg', rating: '5/5' }; modalOpen = true"
          class="absolute left-1/2 -translate-x-1/2 -translate-y-1/3 w-full max-w-[240px] ptablet:max-w-[150px] transition-transform duration-400"
          src="/img/illustrations/doctors/jorge2.png"
          alt="Doctor"
        />
      </div>
      <div class="font-sans px-4 pb-4">
        <h4 class="font-semibold text-muted-800 dark:text-muted-100">
          Lic. Jorge Castellanos
        </h4>
        <p class="text-sm text-muted-400">
          Lic. en Kinesiologia y Fisioterapia
        </p>
      </div>
      <div class="px-4 pb-4">
        <p class="text-sm ptablet:text-xs text-muted-500 dark:text-muted-400">
          Lorem ipsum dolor sit amet, consectetur adipiscing elit. Ergo illi
          intellegunt quid
        </p>
      </div>
    </Card>
  </div>
  <!-- Doctor -->
  <div class="group animate-on-scroll">
    <Card
      class="'cursor-pointer will-change-transform p-0 pt-20 duration-400 hover:shadow-2xl hover:scale-105 hover:bg-slate-300 dark:hover:bg-muted-700 hover:translate-y-[-28px]'"
    >
      <div
        class="relative w-full h-40 rounded-t-lg bg-muted-200 dark:bg-muted-800 overflow-visible -mt-20 mb-4"
      >
        <img
          @click="activeDoctor = { name: 'Lic. Montellano Juan', title: 'Lic. en Kinesiologia y Fisioterapia', bio: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Ergo illi intellegunt quid', img: '/img/illustrations/doctors/juan.jpg', rating: '4.8/5' }; modalOpen = true"
          class="absolute left-1/2 -translate-x-1/2 -translate-y-1/3 w-full max-w-[240px] ptablet:max-w-[150px] transition-transform duration-400"
          src="/img/illustrations/doctors/juan2.png"
          alt="Doctor"
        />
      </div>
      <div class="font-sans px-4 pb-4">
        <h4 class="font-semibold text-muted-800 dark:text-muted-100">
          Lic. Montellano Juan
        </h4>
        <p class="text-sm text-muted-400">
          Lic. en Kinesiologia y Fisioterapia
        </p>
      </div>
      <div class="px-4 pb-4">
        <p class="text-sm ptablet:text-xs text-muted-500 dark:text-muted-400">
          Lorem ipsum dolor sit amet, consectetur adipiscing elit. Ergo illi
          intellegunt quid
        </p>
      </div>
    </Card>
  </div>
  <!-- Doctor -->
  <div class="group animate-on-scroll">
    <Card
      class="'cursor-pointer will-change-transform p-0 pt-20 duration-400 hover:shadow-2xl hover:scale-105 hover:bg-slate-300 dark:hover:bg-muted-700 hover:translate-y-[-28px]'"
    >
      <div
        class="relative w-full h-40 rounded-t-lg bg-muted-200 dark:bg-muted-800 overflow-visible -mt-20 mb-4"
      >
        <img
          @click="activeDoctor = { name: 'Lic. Estrella Eduardo', title: 'Lic. en Kinesiologia y Fisioterapia', bio: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Ergo illi intellegunt quid', img: '/img/illustrations/doctors/eduardo.jpg', rating: '4.5/5' }; modalOpen = true"
          class="absolute left-1/2 -translate-x-1/2 -translate-y-1/3 w-full max-w-[240px] ptablet:max-w-[150px] transition-transform duration-400"
          src="/img/illustrations/doctors/eduardo1.png"
          alt="Doctor"
        />
      </div>
      <div class="font-sans px-4 pb-4">
        <h4 class="font-semibold text-muted-800 dark:text-muted-100">
          Lic. Estrella Eduardo
        </h4>
        <p class="text-sm text-muted-400">
          Lic. en Kinesiologia y Fisioterapia
        </p>
      </div>
      <div class="px-4 pb-4">
        <p class="text-sm ptablet:text-xs text-muted-500 dark:text-muted-400">
          Lorem ipsum dolor sit amet, consectetur adipiscing elit. Ergo illi
          intellegunt quid
        </p>
      </div>
    </Card>
  </div>

  <!-- Modal -->
  <div
    x-cloak
    class="fixed inset-0 z-50 flex items-center justify-center px-4"
    x-show="modalOpen"
  >
    <!-- BACKDROP -->
    <div
      class="absolute inset-0 bg-black/50 backdrop-blur-sm"
      x-show="modalOpen"
      x-transition:enter="transition-opacity duration-300"
      x-transition:enter-start="opacity-0"
      x-transition:enter-end="opacity-100"
      x-transition:leave="transition-opacity duration-200"
      x-transition:leave-start="opacity-100"
      x-transition:leave-end="opacity-0"
      @click="modalOpen = false"
    >
    </div>

    <!-- MODAL -->
    <div
      @click.stop
      x-show="modalOpen"
      x-transition:enter="transition-all duration-300 ease-out"
      x-transition:enter-start="opacity-0 scale-95 translate-y-6"
      x-transition:enter-end="opacity-100 scale-100 translate-y-0"
      x-transition:leave="transition-all duration-200 ease-in"
      x-transition:leave-start="opacity-100 scale-100"
      x-transition:leave-end="opacity-0 scale-95 translate-y-4"
      class="relative z-50 w-full max-w-2xl"
    >
      <div
        class="bg-white dark:bg-muted-900 rounded-2xl shadow-xl overflow-hidden"
      >
        <!-- HEADER -->
        <div
          class="flex items-center justify-between px-5 py-4 border-b border-muted-200 dark:border-muted-800"
        >
          <h3
            class="text-lg font-semibold text-muted-800 dark:text-white"
            x-text="activeDoctor?.name"
          >
          </h3>

          <button
            @click="modalOpen = false"
            class="text-muted-400 hover:text-muted-700 dark:hover:text-white transition"
          >
            ✕
          </button>
        </div>

        <!-- BODY -->
        <div class="p-5 flex flex-col sm:flex-row gap-5">
          <!-- FOTO -->
          <div class="flex-shrink-0 mx-auto sm:mx-0">
            <div
              class="w-60 h-60 sm:w-60 sm:h-60 rounded-xl overflow-hidden bg-muted-200 dark:bg-muted-800"
            >
              <img
                :src="activeDoctor?.img"
                class="w-full h-full object-cover"
              />
            </div>
          </div>

          <!-- INFO -->
          <div class="flex-1 text-center sm:text-left">
            <p
              class="text-sm text-primary-500 font-medium"
              x-text="activeDoctor?.title"
            >
            </p>

            

            <p
              class="mt-4 text-sm text-muted-600 dark:text-muted-300 leading-relaxed"
              x-text="activeDoctor?.bio"
            >
            </p>
          </div>
        </div>

        <!-- FOOTER -->
        <div class="px-5 pb-5 pt-2 flex justify-end">
          <button
            class="px-4 py-2 text-sm rounded-lg bg-primary-500 hover:bg-primary-600 text-white font-medium transition"
            @click="modalOpen = false"
          >
            Cerrar
          </button>
        </div>
      </div>
    </div>
  </div>
</div>
