---
interface Props {
  id: string;
  image: string;
  title: string;
  description: string;
  fullDescription?: string;
}

const { id, image, title, description, fullDescription = description } = Astro.props;
---

<div
  class="group animate-pricing-card cursor-pointer h-full flex flex-col rounded-xl overflow-hidden border border-muted-200 dark:border-muted-700 bg-white dark:bg-muted-900 hover:border-primary-300 dark:hover:border-primary-700 transition-all duration-300 hover:shadow-xl"
  @click="activeTherapy = { id: $el.dataset.id, image: $el.dataset.image, title: $el.dataset.title, description: $el.dataset.description, fullDescription: $el.dataset.fullDescription }; therapyModalOpen = true"
  data-id={id}
  data-image={image}
  data-title={title}
  data-description={description}
  data-full-description={fullDescription}
>
  <!-- Imagen -->
  <div class="relative w-full h-48 overflow-hidden bg-muted-100 dark:bg-muted-800">
    <img
      src={image}
      alt={title}
      class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-300"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-black/30 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
  </div>

  <!-- Contenido -->
  <div class="p-5 flex flex-col justify-between flex-grow">
    <div>
      <h3 class="font-bold text-lg text-muted-800 dark:text-white line-clamp-2 mb-2">
        {title}
      </h3>
      <p class="text-sm text-muted-600 dark:text-muted-400 line-clamp-2">
        {description}
      </p>
    </div>

    <!-- CTA -->
    <div class="pt-4 flex items-center gap-2">
      <p class="text-xs font-semibold text-primary-500 group-hover:text-primary-600 transition-colors">
        Ver más detalles
      </p>
      <iconify-icon
        class="w-4 h-4 text-primary-500 group-hover:translate-x-1 transition-transform"
        icon="mdi:arrow-right"
      ></iconify-icon>
    </div>
  </div>
</div>
