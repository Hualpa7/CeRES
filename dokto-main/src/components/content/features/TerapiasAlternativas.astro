---
import AlternativeTherapyCardGrid from "./AlternativeTherapyCardGrid.astro"

const alternativeTherapies = [
  {
    id: "1",
    title: "Aromaterapia",
    image: "/img/illustrations/tratamientos/kine1.png",
    description: "Terapia con aceites esenciales",
    fullDescription:
      "La aromaterapia utiliza aceites esenciales aromáticos de plantas para promover la salud física y mental. Estos aceites pueden ser inhalados, aplicados en la piel o usados en difusores.",
  },
  {
    id: "2",
    title: "Meditación Guiada",
    image: "/img/illustrations/tratamientos/kine2.png",
    description: "Técnicas de mindfulness y relajación",
    fullDescription:
      "La meditación guiada es una práctica que reduce el estrés, mejora la concentración y promueve el bienestar emocional. Nuestros instructores te guiarán en sesiones personalizadas.",
  },
  {
    id: "3",
    title: "Naturopatía",
    image: "/img/illustrations/tratamientos/kine3.jpg",
    description: "Medicina natural y herbología",
    fullDescription:
      "La naturopatía se enfoca en usar remedios naturales y plantas medicinales para fortalecer el sistema inmunológico y promover la salud integral del cuerpo.",
  },
  {
    id: "4",
    title: "Yoga Terapéutico",
    image: "/img/illustrations/tratamientos/kine4.jpg",
    description: "Posturas y ejercicios de respiración",
    fullDescription:
      "El yoga terapéutico combina posturas, técnicas de respiración y meditación para aliviar dolores, aumentar la flexibilidad y equilibrar cuerpo y mente.",
  },
  {
    id: "5",
    title: "Homeopatía",
    image: "/img/illustrations/tratamientos/kine5.jpg",
    description: "Tratamientos con remedios homeopáticos",
    fullDescription:
      "La homeopatía utiliza sustancias muy diluidas para estimular los mecanismos naturales de curación del cuerpo, tratando la persona de forma holística.",
  },
];
---

<section
  id="terapiasAlternativas"
  class="w-full mx-auto py-8 md:py-12"
  x-data="{ therapyModalOpen: false, activeTherapy: null }"
  x-intersect="activeStep = 'spy-terapias'"
>
  <!-- Header -->
  <div class="max-w-3xl mx-auto mb-12 md:mb-16 text-center px-4">
    <span
      class="inline-block text-xx font-semibold tracking-widest uppercase mb-3 text-primary-500"
    >
      Alternativas Naturales
    </span>
    <h2
      class="font-heading font-bold text-3xl md:text-4xl lg:text-5xl text-muted-800 dark:text-white mb-4"
    >
      Terapias Complementarias
    </h2>
    <p class="text-base md:text-lg text-muted-600 dark:text-muted-400">
      Ofrecemos terapias alternativas y complementarias que se combinan con
      tratamientos tradicionales para optimizar tu bienestar integral.
    </p>
  </div>

  <!-- Therapies Grid -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-6">
    {
      alternativeTherapies.map((therapy) => (
        <AlternativeTherapyCardGrid
          id={therapy.id}
          image={therapy.image}
          title={therapy.title}
          description={therapy.description}
          fullDescription={therapy.fullDescription}
        />
      ))
    }
  </div>

  <!-- Modal para terapias alternativas -->
  <!-- Modal -->
  <div
    x-cloak
    class="fixed inset-0 z-50 flex items-center justify-center"
    x-show="therapyModalOpen && activeTherapy"
  >
    <!-- BACKDROP -->
    <div
      class="absolute inset-0 bg-black/60 backdrop-blur-sm"
      x-show="therapyModalOpen"
      x-transition:enter="transition-opacity ease-out duration-300"
      x-transition:enter-start="opacity-0"
      x-transition:enter-end="opacity-100"
      x-transition:leave="transition-opacity ease-in duration-200"
      x-transition:leave-start="opacity-100"
      x-transition:leave-end="opacity-0"
      @click="therapyModalOpen = false"
    >
    </div>

    <!-- MODAL -->
    <div
      @click.stop
      x-show="therapyModalOpen"
      x-transition:enter="transition transform ease-out duration-300"
      x-transition:enter-start="opacity-0 scale-95 translate-y-4"
      x-transition:enter-end="opacity-100 scale-100 translate-y-0"
      x-transition:leave="transition transform ease-[cubic-bezier(0.4,0,0.2,1)] duration-250"
      x-transition:leave-start="opacity-100 scale-100 translate-y-0"
      x-transition:leave-end="opacity-0 scale-95 translate-y-4"
      class="relative z-50 w-full max-w-md mx-3"
    >
      <div
        class="bg-white dark:bg-muted-900 rounded-2xl shadow-2xl overflow-hidden"
      >
        <!-- IMAGEN -->
        <div class="relative w-full h-64 overflow-hidden">
          <img :src="activeTherapy?.image" class="w-full h-full object-cover" />
        </div>

        <!-- CONTENIDO -->
        <div class="p-6 space-y-4">
          <h3
            class="font-heading font-semibold text-2xl text-muted-800 dark:text-white"
            x-text="activeTherapy?.title"
          >
          </h3>

          <p
            class="text-muted-600 dark:text-muted-400"
            x-text="activeTherapy?.fullDescription"
          >
          </p>

          <!-- BOTÓN -->
          <div class="flex justify-end pt-4">
            <button
              @click="therapyModalOpen = false"
                class="flex-1 px-4 py-3 rounded-lg bg-primary-500 hover:bg-primary-600 text-white font-semibold transition-colors"
            >
              Cerrar
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
