---
import TreatmentCard from "@components/content/features/TreatmentCard.astro";
import '../../../js/components/EmblaCarousel/base.css'
import '../../../js/components/EmblaCarousel/embla.css'

const treatments = [
  {
    id: '1',
    title: 'Kinesiología',
    image: '/img/illustrations/tratamientos/kine1.png',
    description: 'Rehabilitación y fisioterapia especializada',
    fullDescription: 'Ofrecemos servicios de kinesiología y rehabilitación física con profesionales altamente capacitados. Contamos con tecnología moderna para ayudarte a recuperar tu movilidad y bienestar.'
  },
  {
    id: '2',
    title: 'Terapia Física',
    image: '/img/illustrations/tratamientos/kine2.png',
    description: 'Tratamiento de lesiones musculares y óseas',
    fullDescription: 'Especialistas en terapia física que utilizan las mejores técnicas para el tratamiento de lesiones deportivas, dolores crónicos y rehabilitación post-operatoria.'
  },
  {
    id: '3',
    title: 'Masoterapia',
    image: '/img/illustrations/tratamientos/kine3.jpg',
    description: 'Terapia manual y relajación muscular',
    fullDescription: 'Servicios de masaje terapéutico para aliviar tensiones musculares, estrés y dolor crónico. Nuestros masoterapeutas utilizan técnicas comprobadas para tu bienestar.'
  },
  {
    id: '4',
    title: 'Osteopatía',
    image: '/img/illustrations/tratamientos/kine4.jpg',
    description: 'Tratamiento de alteraciones estructurales',
    fullDescription: 'Tratamiento osteopático integral que aborda problemas de la columna vertebral, articulaciones y tejidos blandos para restaurar el equilibrio del cuerpo.'
  },
  {
    id: '5',
    title: 'Acupuntura',
    image: '/img/illustrations/tratamientos/kine5.jpg',
    description: 'Medicina tradicional y alternativa',
    fullDescription: 'Acupuntura y técnicas de medicina tradicional china para el manejo del dolor y promoción de la salud. Combinamos tradición con evidencia científica.'
  }
]
---

<div
  id="tratamientos"
  x-data="{
    modalOpen: false,
    activeCard: null
  }"
  class="flex flex-col lg:flex-row items-stretch gap-8 py-6"
  x-intersect="activeStep = 'spy-2'"
>
  <!--Column Izquierda - Texto-->
  <div class="w-full lg:w-1/4 relative p-6 flex flex-col justify-center">
    <!--Section content-->
    <div class="w-full space-y-4">
      <!--Badge-->
      <h4
        class="font-sans font-semibold text-xs tracking-widest uppercase mb-3 text-primary-500"
      >
        Servicios Médicos
      </h4>
      <!--Title-->
      <h2
        class="font-heading font-medium text-3xl lg:text-4xl text-muted-800 dark:text-white"
      >
        Nuestros Tratamientos
      </h2>
      <!--Subtitle-->
      <p class="font-sans text-base lg:text-lg text-muted-500 dark:text-muted-400">
        Contamos con un equipo de profesionales médicos altamente capacitados para brindarte la mejor atención.
      </p>
    </div>
  </div>

  <!--Column Derecha - Carrusel-->
  <div class="w-full lg:w-3/4 relative p-6">
    <div class="embla">
      <div class="embla__viewport">
        <div class="embla__container">
          {treatments.map((treatment) => (
            <TreatmentCard
              id={treatment.id}
              image={treatment.image}
              title={treatment.title}
              description={treatment.description}
              fullDescription={treatment.fullDescription}
            />
          ))}
        </div>
      </div>
      <div class="embla__controls">
        <div class="embla__buttons">
          <button
            class="embla__button embla__button--prev embla__button--disabled"
            type="button"
          >
            <svg class="embla__button__svg" viewBox="0 0 532 532">
              <path
                fill="currentColor"
                d="M355.66 11.354c13.793-13.805 36.208-13.805 50.001 0 13.785 13.804 13.785 36.238 0 50.034L201.22 266l204.442 204.61c13.785 13.805 13.785 36.239 0 50.044-13.793 13.796-36.208 13.796-50.002 0a5994246.277 5994246.277 0 0 0-229.332-229.454 35.065 35.065 0 0 1-10.326-25.126c0-9.2 3.393-18.26 10.326-25.2C172.192 194.973 332.731 34.31 355.66 11.354Z"
              ></path>
            </svg>
          </button>
          <button
            class="embla__button embla__button--next embla__button--disabled"
            type="button"
          >
            <svg class="embla__button__svg" viewBox="0 0 532 532">
              <path
                fill="currentColor"
                d="M176.34 520.646c-13.793 13.805-36.208 13.805-50.001 0-13.785-13.804-13.785-36.238 0-50.034L330.78 266 126.34 61.391c-13.785-13.805-13.785-36.239 0-50.044 13.793-13.796 36.208-13.796 50.002 0 22.928 22.947 206.395 206.507 229.332 229.454a35.065 35.065 0 0 1 10.326 25.126c0 9.2-3.393 18.26-10.326 25.2-45.865 45.901-206.404 206.564-229.332 229.52Z"
              ></path>
            </svg>
          </button>
        </div>
        <div class="embla__dots"></div>
      </div>
    </div>

    <!-- Modal -->
    <template x-if="modalOpen && activeCard">
      <div
        x-transition:enter="transition ease-out duration-300"
        x-transition:enter-start="opacity-0"
        x-transition:enter-end="opacity-100"
        x-transition:leave="transition ease-in duration-200"
        x-transition:leave-start="opacity-100"
        x-transition:leave-end="opacity-0"
        class="fixed inset-0 bg-black/50 z-40 backdrop-blur-sm flex items-center justify-center"
        @click="modalOpen = false"
      >
        <div
          @click.stop
          class="bg-white dark:bg-muted-900 rounded-lg shadow-2xl max-w-md w-full mx-4 overflow-hidden"
          x-transition:enter="transition ease-out duration-300"
          x-transition:enter-start="opacity-0 scale-95"
          x-transition:enter-end="opacity-100 scale-100"
          x-transition:leave="transition ease-in duration-200"
          x-transition:leave-start="opacity-100 scale-100"
          x-transition:leave-end="opacity-0 scale-95"
        >
          <!-- Image -->
          <div class="relative w-full h-64 overflow-hidden">
            <img
              :src="activeCard.image"
              :alt="activeCard.title"
              class="w-full h-full object-cover"
            />
          </div>

          <!-- Content -->
          <div class="p-6 space-y-4">
            <!-- Title -->
            <h3 class="font-heading font-semibold text-2xl text-muted-800 dark:text-white">
              <span x-text="activeCard.title"></span>
            </h3>

            <!-- Description -->
            <p class="text-muted-600 dark:text-muted-400">
              <span x-text="activeCard.fullDescription"></span>
            </p>

            <!-- Close Button -->
            <div class="flex gap-3 pt-4">
              <button
                @click="modalOpen = false"
                class="flex-1 px-4 py-2 rounded-lg bg-primary-500 hover:bg-primary-600 text-white font-medium transition-colors"
              >
                Cerrar
              </button>
            </div>
          </div>
        </div>
      </div>
    </template>
  </div>
</div>

<script>
  import EmblaCarousel from 'embla-carousel'
  import { addDotButtonAndClickHandlers } from '../../../js/components/EmblaCarousel/EmblaCarouselDotButton'
  import { addPrevNextButtonClickHandlers } from '../../../js/components/EmblaCarousel/EmblaCarouselArrowButtons'

  const OPTIONS = { loop: true }

  // Esperar a que el DOM esté listo
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCarousel)
  } else {
    initCarousel()
  }

  function initCarousel() {
    try {
      const emblaNode = document.querySelector('.embla') as HTMLElement
      if (!emblaNode) {
        console.warn('Embla container not found')
        return
      }

      const viewportNode = emblaNode.querySelector('.embla__viewport') as HTMLElement
      const prevBtn = emblaNode.querySelector('.embla__button--prev') as HTMLElement
      const nextBtn = emblaNode.querySelector('.embla__button--next') as HTMLElement
      const dotsNode = emblaNode.querySelector('.embla__dots') as HTMLElement

      if (!viewportNode) {
        console.warn('Embla viewport not found')
        return
      }

      console.log('Initializing Embla Carousel...')
      const emblaApi = EmblaCarousel(viewportNode, OPTIONS)
      
      console.log('Embla API methods available:', Object.keys(emblaApi).filter(k => typeof emblaApi[k] === 'function'))

      if (prevBtn && nextBtn) {
        console.log('Adding prev/next handlers...')
        addPrevNextButtonClickHandlers(emblaApi, prevBtn, nextBtn)
      } else {
        console.warn('Prev or next button not found')
      }

      if (dotsNode) {
        console.log('Adding dot handlers...')
        addDotButtonAndClickHandlers(emblaApi, dotsNode)
      } else {
        console.warn('Dots container not found')
      }

      console.log('Embla Carousel initialized successfully')
    } catch (error) {
      console.error('Error initializing Embla Carousel:', error)
    }
  }
</script>
