---
interface Props {
  id: string;
  title: string;
  price: string | number;
  description: string;
  features: string[];
  highlighted?: boolean;
  icon?: string;
}

const { id, title, price, description, features, highlighted = false, icon } = Astro.props;
---

<div
  class={`group animate-pricing-card rounded-xl overflow-hidden transition-all duration-300 hover:shadow-2xl hover:scale-105 flex flex-col h-full ${
    highlighted
      ? 'border-2 border-primary-500 shadow-lg shadow-primary-500/20 bg-gradient-to-br from-primary-50 to-white dark:from-primary-900/30 dark:to-muted-900'
      : 'border border-muted-200 dark:border-muted-700 bg-white dark:bg-muted-900 hover:border-primary-300'
  }`}
>
  <!-- Header con icono -->
  <div class={`relative p-6 ${highlighted ? 'bg-gradient-to-r from-primary-500/10 to-primary-500/5 dark:from-primary-500/10 dark:to-transparent border-b border-primary-200 dark:border-primary-900/30' : 'bg-muted-50 dark:bg-muted-800/50 border-b border-muted-100 dark:border-muted-700'}`}>
    {icon && (
      <div class="mb-4 flex items-center justify-center w-12 h-12 rounded-lg bg-primary-500/10 dark:bg-primary-500/20">
        <iconify-icon
          class="w-6 h-6 text-primary-500"
          icon={icon}
        ></iconify-icon>
      </div>
    )}
    <h3 class="text-xl font-bold text-muted-800 dark:text-white mb-1">
      {title}
    </h3>
    <p class="text-xs text-muted-500 dark:text-muted-400 leading-relaxed">
      {description}
    </p>
  </div>

  <!-- Precio -->
  <div class="px-6 pt-6 pb-4">
    <div class="flex items-baseline gap-1">
      <span class="text-5xl font-bold bg-gradient-to-r from-primary-500 to-primary-600 bg-clip-text text-transparent">
        {price}
      </span>
      <span class="text-xs text-muted-500 dark:text-muted-400 font-medium">/sesión</span>
    </div>
  </div>

  <!-- Features -->
  <div class="px-6 py-4 space-y-2.5 flex-grow">
    {features.map((feature) => (
      <div class="flex items-start gap-2.5 text-sm">
        <iconify-icon
          class="w-4 h-4 text-green-500 flex-shrink-0 mt-1"
          icon="mdi:check-circle-outline"
        ></iconify-icon>
        <span class="text-muted-700 dark:text-muted-300 leading-snug">
          {feature}
        </span>
      </div>
    ))}
  </div>

  <!-- CTA Button -->
  <div class="px-6 pb-6 pt-2">
    <button
      class={`w-full py-3 px-4 rounded-lg font-semibold text-sm transition-all duration-300 transform ${
        highlighted
          ? 'bg-gradient-to-r from-primary-500 to-primary-600 hover:from-primary-600 hover:to-primary-700 text-white shadow-lg shadow-primary-500/30 hover:shadow-primary-500/50'
          : 'bg-muted-100 hover:bg-muted-200 dark:bg-muted-800 dark:hover:bg-muted-700 text-muted-800 dark:text-white border border-transparent hover:border-primary-300 dark:hover:border-primary-700'
      }`}
    >
      Reservar Sesión
    </button>
  </div>
</div>

