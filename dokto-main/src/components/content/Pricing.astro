---
import AlternativeTherapyCard from "@components/content/features/AlternativeTherapyCard.astro";
import '../../js/components/EmblaCarousel/base.css'
import '../../js/components/EmblaCarousel/embla.css'

const alternativeTherapies = [
  {
    id: '1',
    title: 'Aromaterapia',
    image: '/img/illustrations/tratamientos/kine1.png',
    description: 'Terapia con aceites esenciales',
    fullDescription: 'La aromaterapia utiliza aceites esenciales aromáticos de plantas para promover la salud física y mental. Estos aceites pueden ser inhalados, aplicados en la piel o usados en difusores.'
  },
  {
    id: '2',
    title: 'Meditación Guiada',
    image: '/img/illustrations/tratamientos/kine2.png',
    description: 'Técnicas de mindfulness y relajación',
    fullDescription: 'La meditación guiada es una práctica que reduce el estrés, mejora la concentración y promueve el bienestar emocional. Nuestros instructores te guiarán en sesiones personalizadas.'
  },
  {
    id: '3',
    title: 'Naturopatía',
    image: '/img/illustrations/tratamientos/kine3.jpg',
    description: 'Medicina natural y herbología',
    fullDescription: 'La naturopatía se enfoca en usar remedios naturales y plantas medicinales para fortalecer el sistema inmunológico y promover la salud integral del cuerpo.'
  },
  {
    id: '4',
    title: 'Yoga Terapéutico',
    image: '/img/illustrations/tratamientos/kine4.jpg',
    description: 'Posturas y ejercicios de respiración',
    fullDescription: 'El yoga terapéutico combina posturas, técnicas de respiración y meditación para aliviar dolores, aumentar la flexibilidad y equilibrar cuerpo y mente.'
  },
  {
    id: '5',
    title: 'Homeopatía',
    image: '/img/illustrations/tratamientos/kine5.jpg',
    description: 'Tratamientos con remedios homeopáticos',
    fullDescription: 'La homeopatía utiliza sustancias muy diluidas para estimular los mecanismos naturales de curación del cuerpo, tratando la persona de forma holística.'
  }
]
---


<!-- NUEVA SECCIÓN: TERAPIAS ALTERNATIVAS CON CARRUSEL -->
<div id="terapiasAlternativas" class="w-full max-w-6xl mx-auto mt-16" x-intersect="activeStep = 'spy-4'">
  <div class="p-6 md:p-10">
    <div
      x-data="{
        therapyModalOpen: false,
        activeTherapy: null
      }"
      class="flex flex-col lg:flex-row items-stretch gap-8"
    >
      <!-- Carrusel Izquierdo -->
      <div class="w-full lg:w-3/4 relative">
        <div class="embla-therapy">
          <div class="embla__viewport">
            <div class="embla__container">
              {alternativeTherapies.map((therapy) => (
                <AlternativeTherapyCard
                  id={therapy.id}
                  image={therapy.image}
                  title={therapy.title}
                  description={therapy.description}
                  fullDescription={therapy.fullDescription}
                />
              ))}
            </div>
          </div>
          <div class="embla__controls">
            <div class="embla__buttons">
              <button
                class="embla__button embla__button--prev embla__button--disabled"
                type="button"
              >
                <svg class="embla__button__svg" viewBox="0 0 532 532">
                  <path
                    fill="currentColor"
                    d="M355.66 11.354c13.793-13.805 36.208-13.805 50.001 0 13.785 13.804 13.785 36.238 0 50.034L201.22 266l204.442 204.61c13.785 13.805 13.785 36.239 0 50.044-13.793 13.796-36.208 13.796-50.002 0a5994246.277 5994246.277 0 0 0-229.332-229.454 35.065 35.065 0 0 1-10.326-25.126c0-9.2 3.393-18.26 10.326-25.2C172.192 194.973 332.731 34.31 355.66 11.354Z"
                  ></path>
                </svg>
              </button>
              <button
                class="embla__button embla__button--next embla__button--disabled"
                type="button"
              >
                <svg class="embla__button__svg" viewBox="0 0 532 532">
                  <path
                    fill="currentColor"
                    d="M176.34 520.646c-13.793 13.805-36.208 13.805-50.001 0-13.785-13.804-13.785-36.238 0-50.034L330.78 266 126.34 61.391c-13.785-13.805-13.785-36.239 0-50.044 13.793-13.796 36.208-13.796 50.002 0 22.928 22.947 206.395 206.507 229.332 229.454a35.065 35.065 0 0 1 10.326 25.126c0 9.2-3.393 18.26-10.326 25.2-45.865 45.901-206.404 206.564-229.332 229.52Z"
                  ></path>
                </svg>
              </button>
            </div>
            <div class="embla__dots"></div>
          </div>
        </div>

        <!-- Modal para terapias alternativas -->
        <template x-if="therapyModalOpen && activeTherapy">
          <div
            x-transition:enter="transition ease-out duration-300"
            x-transition:enter-start="opacity-0"
            x-transition:enter-end="opacity-100"
            x-transition:leave="transition ease-in duration-200"
            x-transition:leave-start="opacity-100"
            x-transition:leave-end="opacity-0"
            class="fixed inset-0 bg-black/50 z-40 backdrop-blur-sm flex items-center justify-center"
            @click="therapyModalOpen = false"
          >
            <div
              @click.stop
              class="bg-white dark:bg-muted-900 rounded-lg shadow-2xl max-w-md w-full mx-4 overflow-hidden"
              x-transition:enter="transition ease-out duration-300"
              x-transition:enter-start="opacity-0 scale-95"
              x-transition:enter-end="opacity-100 scale-100"
              x-transition:leave="transition ease-in duration-200"
              x-transition:leave-start="opacity-100 scale-100"
              x-transition:leave-end="opacity-0 scale-95"
            >
              <div class="relative w-full h-64 overflow-hidden">
                <img
                  :src="activeTherapy.image"
                  :alt="activeTherapy.title"
                  class="w-full h-full object-cover"
                />
              </div>
              <div class="p-6 space-y-4">
                <h3 class="font-heading font-semibold text-2xl text-muted-800 dark:text-white">
                  <span x-text="activeTherapy.title"></span>
                </h3>
                <p class="text-muted-600 dark:text-muted-400">
                  <span x-text="activeTherapy.fullDescription"></span>
                </p>
                <div class="flex gap-3 pt-4">
                  <button
                    @click="therapyModalOpen = false"
                    class="flex-1 px-4 py-2 rounded-lg bg-primary-500 hover:bg-primary-600 text-white font-medium transition-colors"
                  >
                    Cerrar
                  </button>
                </div>
              </div>
            </div>
          </div>
        </template>
      </div>

      <!-- Información Derecha -->
      <div class="w-full lg:w-1/4 relative p-6 flex flex-col justify-center">
        <div class="w-full space-y-4">
          <h4
            class="font-sans font-semibold text-xs tracking-widest uppercase mb-3 text-primary-500"
          >
            Alternativas Naturales
          </h4>
          <h2
            class="font-heading font-medium text-3xl lg:text-4xl text-muted-800 dark:text-white"
          >
            Terapias Complementarias
          </h2>
          <p class="font-sans text-base lg:text-lg text-muted-500 dark:text-muted-400">
            Ofrecemos terapias alternativas y complementarias que se combinan con tratamientos tradicionales para optimizar tu bienestar integral.
          </p>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  import EmblaCarousel from 'embla-carousel'
  import { addDotButtonAndClickHandlers } from '../../js/components/EmblaCarousel/EmblaCarouselDotButton'
  import { addPrevNextButtonClickHandlers } from '../../js/components/EmblaCarousel/EmblaCarouselArrowButtons'

  const OPTIONS = { loop: true }

  // Esperar a que el DOM esté listo
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initTherapyCarousel)
  } else {
    initTherapyCarousel()
  }

  function initTherapyCarousel() {
    try {
      const emblaNode = document.querySelector('.embla-therapy') as HTMLElement
      if (!emblaNode) {
        console.warn('Therapy carousel container not found')
        return
      }

      const viewportNode = emblaNode.querySelector('.embla__viewport') as HTMLElement
      const prevBtn = emblaNode.querySelector('.embla__button--prev') as HTMLElement
      const nextBtn = emblaNode.querySelector('.embla__button--next') as HTMLElement
      const dotsNode = emblaNode.querySelector('.embla__dots') as HTMLElement

      if (!viewportNode) {
        console.warn('Therapy carousel viewport not found')
        return
      }

      console.log('Initializing Therapy Embla Carousel...')
      const emblaApi = EmblaCarousel(viewportNode, OPTIONS)

      if (prevBtn && nextBtn) {
        console.log('Adding therapy carousel prev/next handlers...')
        addPrevNextButtonClickHandlers(emblaApi, prevBtn, nextBtn)
      }

      if (dotsNode) {
        console.log('Adding therapy carousel dot handlers...')
        addDotButtonAndClickHandlers(emblaApi, dotsNode)
      }

      console.log('Therapy Embla Carousel initialized successfully')
    } catch (error) {
      console.error('Error initializing Therapy Carousel:', error)
    }
  }
</script>
