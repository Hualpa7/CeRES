---
import Container from "@components/section/Container.astro";
import Logo from "@components/base/Logo.astro";
---

<footer class="font-sans bg-white dark:bg-muted-900">
  
  <!-- Sección de Ubicación con Mapa -->
  <div class="border-t border-muted-200 dark:border-muted-800">
    <Container>
      <div class="px-5 py-12 mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-center">
          <!-- Información de Contacto -->
          <div class="flex flex-col justify-center">
            <h3 class="text-2xl md:text-3xl font-semibold text-muted-900 dark:text-white mb-4">
              Nuestra Ubicación
            </h3>
            <p class="text-muted-600 dark:text-muted-300 mb-6">
              Encontranos en el corazón de Salta
            </p>
            <div class="space-y-4">
              <div class="flex items-start gap-3">
                <iconify-icon icon="fa6-solid:location-dot" class="text-primary-500 mt-1 flex-shrink-0"></iconify-icon>
                <div>
                  <p class="font-semibold text-muted-800 dark:text-muted-100">Dirección</p>
                  <p class="text-sm text-muted-600 dark:text-muted-400">
                    25 de Mayo 629, A4400 Salta, Argentina
                  </p>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <iconify-icon icon="fa6-solid:phone" class="text-primary-500 mt-1 flex-shrink-0"></iconify-icon>
                <div>
                  <p class="font-semibold text-muted-800 dark:text-muted-100">Teléfono</p>
                  <p class="text-sm text-muted-600 dark:text-muted-400">
                    Llamanos para más información
                  </p>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <iconify-icon icon="fa6-solid:envelope" class="text-primary-500 mt-1 flex-shrink-0"></iconify-icon>
                <div>
                  <p class="font-semibold text-muted-800 dark:text-muted-100">Email</p>
                  <p class="text-sm text-muted-600 dark:text-muted-400">
                    info@ceres.com.ar
                  </p>
                </div>
              </div>
            </div>
          </div>

          <!-- Mapa de Google Maps -->
          <div class="relative w-full h-80 rounded-lg overflow-hidden shadow-lg">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3579.766840419385!2d-65.40840612345!3d-24.787600275000!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x941b5f5c3e5c5c5d%3A0x5c3e5c5c3e5c5c5e!2s25%20de%20Mayo%20629%2C%20A4400%20Salta!5e0!3m2!1ses-ES!2sar!4v1234567890"
              width="100%"
              height="100%"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              class="absolute inset-0"
            />
          </div>
        </div>
      </div>
    </Container>
  </div>

  <div class="border-t border-muted-200 dark:border-muted-800">
    <Container>
      <div class="px-5 py-8 flex flex-col md:flex-row mx-auto items-center">
        
        <span
          class="inline-flex ltablet:ml-auto lg:ml-auto md:mt-0 mt-6 w-full justify-center md:justify-start md:w-auto"
        >
          <a href="#" class="text-muted-500">
            <iconify-icon class="iconify w-5 h-5 flex items-center justify-center text-md" icon="fa6-brands:facebook-f"></iconify-icon>
          </a>
          <a href="#" class="ml-3 text-muted-500">
            <iconify-icon class="iconify w-5 h-5 flex items-center justify-center text-md" icon="fa6-brands:twitter"></iconify-icon>
          </a>
          <a href="https://www.instagram.com/ceressalta?utm_source=ig_web_button_share_sheet&igsh=ZDNlZDc0MzIxNw==" class="ml-3 text-muted-500">
            <iconify-icon class="iconify w-5 h-5 flex items-center justify-center text-md" icon="fa6-brands:instagram"></iconify-icon>
          </a>
          <a href="#" class="ml-3 text-muted-500">
            <iconify-icon class="iconify w-5 h-5 flex items-center justify-center text-md" icon="fa6-brands:linkedin-in"></iconify-icon>
          </a>
        </span>
      </div>
    </Container>
  </div>

  <div class="bg-muted-100 dark:bg-muted-800">
    <Container>
      <div class="py-4 px-5 flex flex-wrap flex-col sm:flex-row">
        <p
          class="text-muted-500 dark:text-muted-400 text-sm text-center sm:text-left"
        >
          © 2018-{new Date().getFullYear()} All Rights Reserved —
          <a
            href="https://cssninja.io"
            class="hover:text-primary-500"
            target="_blank"
            rel="noopener noreferrer">Css Ninja</a
          >
        </p>
        <span
          class="sm:ml-auto sm:mt-0 mt-2 sm:w-auto w-full sm:text-left text-center text-muted-500 dark:text-muted-400 text-sm"
          >Built with <a href="https://astro.build" class="hover:text-primary-500"
            >Astro.build</a
          >
        </span>
      </div>
    </Container>
  </div>
</footer>
